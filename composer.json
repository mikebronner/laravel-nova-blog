{
    "name": "genealabs/laravel-nova-blog",
    "description": "Drop-in Blog module for Laravel using Nova as an admin panel.",
    "keywords": [
        "laravel",
        "nova"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ],
    "require": {
        "cviebrock/eloquent-sluggable": "*",
        "genealabs/laravel-nova-morph-many-to-one": "dev-master",
        "genealabs/laravel-overridable-model": "*",
        "genealabs/nova-file-upload-field": "*",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "jenssegers/model": "^1.5",
        "laravel/nova": "^4.0|^5.0",
        "laravel/scout": "^10.0|^11.0|^12.0|^13.0",
        "saumini/count": "*",
        "symfony/thanks": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "GeneaLabs\\LaravelNovaBlog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GeneaLabs\\LaravelNovaBlog\\Providers\\Service",
                "GeneaLabs\\LaravelNovaBlog\\Providers\\Nova"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/thanks": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
